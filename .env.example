# ============================================================================
# TravelPlan — environment variables
# ============================================================================
# Copy to .env.local and fill in values. Never commit real secrets.

# ---- Required ----
# Generate with: openssl rand -base64 64
JWT_SECRET=

# Database (Postgres in dev via docker-compose, RDS in prod)
DATABASE_URL=postgresql://travelplan:travelplan_dev_only@localhost:5432/travelplan

# Anthropic — get at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ---- Recommended ----
# Redis for shared rate limit (ElastiCache in prod)
REDIS_URL=redis://localhost:6379

# Public URL of this app. MUST be https:// in production.
NEXT_PUBLIC_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# ---- Optional ----
# Google OAuth — console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SerpApi for flight/hotel prices
SERPAPI_KEY=

# Comma-separated admin emails for /admin/analytics
ADMIN_EMAILS=

# ---- Production-only ----
# AWS Secrets Manager — if set, app pulls JSON of all secrets from this secret on startup
# IAM role of the ECS task needs secretsmanager:GetSecretValue on this ARN
# AWS_SECRETS_ID=travelplan/prod/secrets
# AWS_REGION=us-east-1

# App version for /api/health and CloudWatch metrics
# APP_VERSION=1.0.0
