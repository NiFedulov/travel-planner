  "eta_required": {
    "US": {
      "name": "ESTA",
      "cost_usd": 21,
      "valid_days": 730,
      "exempt_passports": ["US"],
      "applies_to_visa_waiver_countries": true,
      "url": "https://esta.cbp.dhs.gov"
    },
    "CA": {
      "name": "eTA",
      "cost_usd": 7,
      "currency": "CAD",
      "valid_years": 5,
      "exempt": ["US"],
      "url": "https://www.canada.ca/en/immigration-refugees-citizenship/services/visit-canada/eta.html"
    },
    "GB": {
      "name": "UK ETA",
      "cost_gbp": 10,
      "valid_years": 2,
      "url": "https://www.gov.uk/guidance/apply-for-an-electronic-travel-authorisation-eta"
    },
    "AU": {
      "name": "ETA / eVisitor",
      "cost_aud": 20,
      "notes": "eVisitor free for EU/EEA passports",
      "url": "https://immi.homeaffairs.gov.au/visas/getting-a-visa/visa-listing/electronic-travel-authority-601"
    },
    "IN": {
      "name": "e-Visa",
      "cost_usd": 25,
      "notes": "Cost varies by nationality and duration",
      "url": "https://indianvisaonline.gov.in"
    },
    "LK": {
      "name": "ETA",
      "cost_usd": 35,
      "url": "https://www.eta.gov.lk"
    },
    "KE": {
      "name": "eTA",
      "cost_usd": 30,
      "url": "https://www.etakenya.go.ke"
    },
    "RW": {
      "name": "e-Visa",
      "cost_usd": 30,
      "url": "https://irembo.gov.rw"
    }
  },
  "insurance_required": {
    "schengen": {
      "required": true,
      "min_coverage_eur": 30000,
      "notes": "Must cover medical + repatriation"
    },
    "CU": {
      "required": true,
      "notes": "Available at airport on arrival"
    },
    "RU": {
      "required": true,
      "notes": "Required for visa application"
    }
